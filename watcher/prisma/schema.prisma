generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vault {
  address         String       @id
  virtualUsdc     Decimal      @map("virtual_usdc") @db.Decimal(20, 6)
  startingCapital Decimal      @map("starting_capital") @db.Decimal(20, 6)
  copyModelKey    String       @default("fixed_available_pct") @map("copy_model_key")
  copyModelConfig Json         @default("{}") @map("copy_model_config")
  follows         Follow[]
  paperTrades     PaperTrade[]

  @@map("vaults")
}

model Follow {
  follower String
  leader   String
  vault    Vault  @relation(fields: [follower], references: [address])

  @@id([follower, leader])
  @@map("follows")
}

model LeaderSwap {
  id         String   @id @default(uuid())
  leader     String
  side       String
  tokenIn    String   @map("token_in")
  tokenOut   String   @map("token_out")
  usdValue   Decimal  @map("usd_value")  @db.Decimal(20, 6)
  wsomiPrice Decimal  @map("wsomi_price") @db.Decimal(20, 10)
  txHash     String?  @map("tx_hash")
  timestamp  DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([leader, timestamp(sort: Desc)])
  @@map("leader_swaps")
}

model PaperTrade {
  id          String    @id @default(uuid())
  follower    String
  leader      String
  side        String
  token       String
  usdcSpent   Decimal   @map("usdc_spent") @db.Decimal(20, 6)
  tokenAmount Decimal   @map("token_amount") @db.Decimal(30, 10)
  entryPrice  Decimal   @map("entry_price") @db.Decimal(20, 10)
  exitPrice   Decimal?  @map("exit_price") @db.Decimal(20, 10)
  pnl         Decimal?  @db.Decimal(20, 6)
  status      String    @default("OPEN")
  txHash      String?   @map("tx_hash")
  timestamp   DateTime
  vault       Vault     @relation(fields: [follower], references: [address])

  @@map("paper_trades")
}

// ── New on-chain vault system ─────────────────────────────────────────────────

model UserVault {
  id             String     @id @default(uuid())
  follower       String
  leader         String
  ausdcLocked    Decimal    @map("ausdc_locked")     @db.Decimal(20, 6)
  riskLevel      Int        @map("risk_level")
  maxPerTradePct Int        @map("max_per_trade_pct")
  allowlistJson  Json       @default("[]")           @map("allowlist_json")
  stopLossPct    Int        @default(20)             @map("stop_loss_pct")
  status         String     @default("ACTIVE")
  onChainVaultId String?    @map("on_chain_vault_id")
  createdAt      DateTime   @default(now())          @map("created_at")
  positions      Position[]

  @@unique([follower, leader])
  @@index([follower])
  @@index([leader])
  @@map("user_vaults")
}

model Position {
  id                String     @id @default(uuid())
  follower          String
  leader            String
  vaultId           String     @map("vault_id")
  token             String
  ausdcAllocated    Decimal    @map("ausdc_allocated")     @db.Decimal(20, 6)
  entryPrice        Decimal    @map("entry_price")         @db.Decimal(20, 10)
  exitPrice         Decimal?   @map("exit_price")          @db.Decimal(20, 10)
  pnl               Decimal?   @db.Decimal(20, 6)
  status            String     @default("OPEN")
  onChainPositionId String?    @map("on_chain_position_id")
  openedAt          DateTime   @map("opened_at")
  closedAt          DateTime?  @map("closed_at")
  txHashOpen        String?    @map("tx_hash_open")
  txHashClose       String?    @map("tx_hash_close")
  closeReason       String?    @map("close_reason")
  latencyMs         Int?       @map("latency_ms")
  vault             UserVault  @relation(fields: [vaultId], references: [id])

  @@index([follower, status])
  @@index([leader, status])
  @@index([token])
  @@map("positions")
}

model TokenPrice {
  token     String   @id
  price     Decimal  @db.Decimal(20, 10)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("token_prices")
}

model TradeExplanation {
  requestId   String   @id @map("request_id")
  explanation String   @map("explanation")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("trade_explanations")
}

model FollowerProfile {
  follower      String   @id @map("follower")
  email         String   @map("email")
  notifications Boolean  @default(true) @map("notifications")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("follower_profiles")
}
